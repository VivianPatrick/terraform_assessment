# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control — it contains sensitive data.

# AWS region to deploy into
region = "us-east-1"

# Availability zones within the chosen region
availability_zones = ["us-east-1a", "us-east-1b"]

# Your current public IP in CIDR notation — restricts SSH access to the bastion
# Find yours by running: curl -s https://checkip.amazonaws.com
my_ip_address = "YOUR_PUBLIC_IP/32"

# EC2 instance types
bastion_instance_type = "t3.micro"
web_instance_type     = "t3.micro"
db_instance_type      = "t3.small"

# (Optional) Name of an existing EC2 Key Pair for SSH key-based access.
# Leave empty ("") to use username/password only.
key_pair_name = ""

# Password set on ec2-user for all servers (bastion, web, db)
# Use a strong password — minimum 12 characters recommended
bastion_password = "CHANGE_ME_STRONG_PASSWORD"
